<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>日文 N5 雲端題庫版</title>
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
    <style>
        body { font-family: sans-serif; background: #dfe6e9; margin: 0; display: flex; justify-content: center; }
        .app { width: 100%; max-width: 400px; background: white; min-height: 100vh; padding: 20px; box-sizing: border-box; }
        .page { display: none; flex-direction: column; gap: 15px; }
        .page.active { display: flex; }
        h1 { color: #6c5ce7; text-align: center; }
        button { padding: 12px; border-radius: 8px; border: none; background: #6c5ce7; color: white; font-weight: bold; cursor: pointer; }
        .canvas-wrapper { width: 100%; height: 250px; border: 2px solid #ddd; border-radius: 10px; touch-action: none; }
        canvas { width: 100%; height: 100%; display: block; }
        .status-bar { font-size: 0.8rem; text-align: center; color: #95a5a6; margin-bottom: 10px; }
        .list-item { padding: 5px; border-bottom: 1px solid #eee; font-size: 0.8rem; }
    </style>
</head>
<body>

<div class="app">
    <div id="page-home" class="page active">
        <h1>🇯🇵 N5 雲端學習</h1>
        <div id="load-status" class="status-bar">正在同步雲端題庫...</div>
        <button onclick="goTo('page-quiz')">開始測驗</button>
        <button onclick="goTo('page-manage')">查看目前題庫</button>
        <button onclick="goTo('page-review')">錯字回顧</button>
    </div>

    <div id="page-quiz" class="page">
        <button onclick="goTo('page-home')">⬅️ 返回</button>
        <div id="quiz-display" style="font-size: 2.2rem; text-align: center; color: #6c5ce7; font-weight: bold; padding: 10px;"></div>
        <div class="canvas-wrapper"><canvas id="hwCanvas"></canvas></div>
        <button style="background:#636e72; margin-top:10px;" onclick="sigPad.clear()">清除</button>
        <button id="check-btn" onclick="checkAnswer()">提交辨識</button>
        <button id="next-btn" style="background:#00b894; display:none;" onclick="nextQuestion()">下一題</button>
        <div id="result" style="text-align: center; font-weight: bold; margin-top: 10px;"></div>
    </div>

    <div id="page-manage" class="page">
        <button onclick="goTo('page-home')">⬅️ 返回</button>
        <h3>目前載入的單字 (共 <span id="word-count">0</span> 字)</h3>
        <div id="word-list" style="max-height: 400px; overflow-y: auto;"></div>
    </div>

    <div id="page-review" class="page">
        <button onclick="goTo('page-home')">⬅️ 返回</button>
        <div id="review-list"></div>
    </div>
</div>

<script>
    // 1. 設定遠端資料庫網址 (這是 Raw JSON 連結)
    // 如果你想換成自己的，只需去 GitHub Gist 建立一個 JSON 檔並取其 Raw 連結
    const REMOTE_DB_URL = 'https://gist.githubusercontent.com/Luminus0zzz/f52cdc0ce375264f0c0093bc794373fe/raw/3edc164e57607c89c7706904005f916b2209862e/words.json';

    let wordBank = [];
    let remainingWords = [];
    let currentWord = {};
    let sigPad;
    const canvas = document.getElementById('hwCanvas');

    // 2. 核心：非同步抓取遠端資料
    async function syncDatabase() {
        const statusEl = document.getElementById('load-status');
        try {
            // 加上 t=${Date.now()} 防止瀏覽器讀取舊的暫存檔
            const response = await fetch(`${REMOTE_DB_URL}?t=${Date.now()}`);
            if (!response.ok) throw new Error('網路回應不完全');
            
            const data = await response.json();
            wordBank = data;
            
            statusEl.innerText = `✅ 雲端同步成功：共 ${wordBank.length} 個單字`;
            localStorage.setItem('cached_words', JSON.stringify(wordBank)); // 存一份備份到本地
        } catch (error) {
            console.error('雲端抓取失敗:', error);
            statusEl.innerText = '⚠️ 雲端連接失敗，載入本地備份';
            wordBank = JSON.parse(localStorage.getItem('cached_words')) || [{ch:"載入失敗", jp:["error"]}];
        }
        document.getElementById('word-count').innerText = wordBank.length;
    }

    // 初始化執行
    syncDatabase();

    // 3. 頁面與測驗邏輯
    function goTo(pageId) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById(pageId).classList.add('active');
        if(pageId === 'page-quiz') { 
            remainingWords = [...wordBank]; 
            setTimeout(initPad, 50); 
            nextQuestion(); 
        }
        if(pageId === 'page-manage') renderList();
    }

    function initPad() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width; canvas.height = rect.height;
        sigPad = new SignaturePad(canvas, { minWidth: 2, maxWidth: 4 });
    }

    function nextQuestion() {
        if (remainingWords.length === 0) { remainingWords = [...wordBank]; }
        const idx = Math.floor(Math.random() * remainingWords.length);
        currentWord = remainingWords.splice(idx, 1)[0];
        document.getElementById('quiz-display').innerText = currentWord.ch;
        document.getElementById('result').innerText = "";
        document.getElementById('next-btn').style.display = "none";
        document.getElementById('check-btn').style.display = "block";
        if(sigPad) sigPad.clear();
    }

    async function checkAnswer() {
        const traces = sigPad.toData().map(s => [s.points.map(p=>p.x), s.points.map(p=>p.y), []]);
        const res = await fetch('https://www.google.com.tw/inputtools/request?ime=handwriting&app=mobilesearch&cs=1&oe=UTF-8', {
            method: 'POST',
            body: JSON.stringify({ "requests": [{ "writing_guide": { "writing_area_width": canvas.width, "writing_area_height": canvas.height }, "ink": traces, "language": "ja" }] }),
            headers: { 'Content-Type': 'application/json' }
        });
        const result = await res.json();
        const candidates = result[1][0][1];
        
        if (candidates.some(c => currentWord.jp.includes(c.trim()))) {
            document.getElementById('result').style.color = "green";
            document.getElementById('result').innerText = "✅ 正確！";
            document.getElementById('next-btn').style.display = "block";
            document.getElementById('check-btn').style.display = "none";
        } else {
            document.getElementById('result').style.color = "red";
            document.getElementById('result').innerHTML = `❌ 錯誤！正確：${currentWord.jp.join(' 或 ')}`;
        }
    }

    function renderList() {
        document.getElementById('word-list').innerHTML = wordBank.map(w => `<div class='list-item'>${w.ch} : ${w.jp.join(', ')}</div>`).join('');
    }
</script>
</body>
</html>
